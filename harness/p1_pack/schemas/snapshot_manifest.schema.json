{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CertifiedInputPackSnapshotManifestV2",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "columns": { "type": "array", "items": { "type": "string" } },
        "dataset_name": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "rows": { "type": "integer", "minimum": 0 },
        "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
      },
      "required": ["dataset_name", "path", "sha256", "rows", "columns"]
    }
  },
  "properties": {
    "schema_version": { "const": "v2" },
    "snapshot_kind": { "enum": ["raw", "canonical"] },
    "as_of": { "type": "string", "format": "date" },
    "artifacts": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/artifact" } }
  },
  "required": ["schema_version", "snapshot_kind", "as_of", "artifacts"]
}
