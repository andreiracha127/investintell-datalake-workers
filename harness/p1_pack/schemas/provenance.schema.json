{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CertifiedInputPackProvenanceV2",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "dataset": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "dataset_name": { "type": "string", "minLength": 1 },
        "dataset_namespace": { "type": "string", "minLength": 1 },
        "snapshot_id": { "type": "string", "minLength": 1 }
      },
      "required": ["dataset_namespace", "dataset_name", "snapshot_id"]
    },
    "job": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "job_name": { "type": "string", "minLength": 1 },
        "job_namespace": { "type": "string", "minLength": 1 }
      },
      "required": ["job_namespace", "job_name"]
    },
    "run": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "job_name": { "type": "string", "minLength": 1 },
        "run_id": { "type": "string", "minLength": 1 },
        "export_id": { "type": "string", "minLength": 1 }
      },
      "required": ["run_id", "job_name"]
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "source_commit": { "type": "string", "pattern": "^[0-9a-f]{7,40}$" },
        "source_repo": { "const": "investintell-datalake-workers" }
      },
      "required": ["source_repo", "source_commit"]
    }
  },
  "properties": {
    "schema_version": { "const": "v2" },
    "datasets": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/dataset" } },
    "jobs": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/job" } },
    "runs": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/run" } },
    "sources": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/source" } }
  },
  "required": ["schema_version", "datasets", "jobs", "runs", "sources"]
}
