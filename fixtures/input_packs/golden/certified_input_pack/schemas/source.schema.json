{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "builder_commit": {
      "pattern": "^[0-9a-f]{7,40}$",
      "type": "string"
    },
    "builder_code_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "builder_image_digest": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "type": "string"
    },
    "builder_name": {
      "minLength": 1,
      "type": "string"
    },
    "source_commit": {
      "pattern": "^[0-9a-f]{7,40}$",
      "type": "string"
    },
    "source_repo": {
      "const": "investintell-datalake-workers",
      "type": "string"
    }
  },
  "required": [
    "source_repo",
    "source_commit",
    "builder_commit",
    "builder_code_sha256",
    "builder_name"
  ],
  "title": "CertifiedInputPackSourceV1",
  "type": "object"
}

