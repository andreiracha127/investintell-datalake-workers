{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CertifiedInputPackManifestV2",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "input_pack_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_-]*$" },
    "input_pack_version": { "const": 2 },
    "as_of": { "type": "string", "format": "date" },
    "contract_bundle_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "source_repo": { "const": "investintell-datalake-workers" },
    "source_commit": { "type": "string", "pattern": "^[0-9a-f]{7,40}$" },
    "builder_commit": { "type": "string", "pattern": "^[0-9a-f]{7,40}$" },
    "builder_code_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "source_export_id": { "type": "string", "minLength": 1 },
    "raw_snapshot_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "canonical_snapshot_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "input_pack_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "raw_equals_canonical": { "const": true },
    "has_derived_layer": { "const": false },
    "runtime_activation": { "const": false },
    "A5": { "const": "blocked" },
    "activation_allowed": { "const": false },
    "official_result": { "const": false },
    "allocator_publish": { "const": false },
    "db_write_mode": { "const": "none" },
    "classification": { "const": "metric_evidence_only" }
  },
  "required": [
    "input_pack_id",
    "input_pack_version",
    "as_of",
    "contract_bundle_sha256",
    "source_repo",
    "source_commit",
    "builder_commit",
    "builder_code_sha256",
    "source_export_id",
    "raw_snapshot_sha256",
    "canonical_snapshot_sha256",
    "input_pack_sha256",
    "raw_equals_canonical",
    "has_derived_layer",
    "runtime_activation",
    "A5",
    "activation_allowed",
    "official_result",
    "allocator_publish",
    "db_write_mode",
    "classification"
  ]
}
