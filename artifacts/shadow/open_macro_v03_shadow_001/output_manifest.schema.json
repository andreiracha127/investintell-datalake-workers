{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://investintell.local/artifacts/shadow/open_macro_v03_shadow_001/output_manifest.schema.json",
  "title": "OpenMacroV03ShadowPilotOutputManifest001",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "sha256Hex": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    }
  },
  "required": [
    "schema_version",
    "artifact_type",
    "shadow_pilot_id",
    "shadow_id",
    "status",
    "artifacts",
    "logs_required",
    "unexpected_outputs"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "artifact_type": {
      "const": "shadow_pilot_output_manifest"
    },
    "shadow_pilot_id": {
      "const": "open_macro_v03_shadow_pilot_001"
    },
    "shadow_id": {
      "const": "open_macro_v03_shadow_001"
    },
    "status": {
      "const": "succeeded"
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "sha256", "bytes"],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "sha256": {
            "$ref": "#/$defs/sha256Hex"
          },
          "bytes": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    },
    "logs_required": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "unexpected_outputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
