{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://investintell.local/contracts/quant-engine/v2/job-result.schema.json",
  "title": "QuantEngineJobResult",
  "oneOf": [
    {"$ref": "#/$defs/a3_qc_parity_result"},
    {"$ref": "#/$defs/certified_input_pack_dry_run_result"},
    {"$ref": "#/$defs/open_macro_v03_metric_backtest_result"}
  ],
  "$defs": {
    "sha256Hex": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "a3_qc_parity_result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "job_type",
        "job_id",
        "execution_id",
        "run_fingerprint",
        "status",
        "classification",
        "jobs",
        "artifact_prefix",
        "output_logical_hashes",
        "errors",
        "runtime_activation",
        "a3_status",
        "a4_status",
        "a5_status"
      ],
      "properties": {
        "schema_version": {"const": 1},
        "job_type": {"const": "a3_qc_parity"},
        "job_id": {"type": "string", "minLength": 1},
        "execution_id": {"type": "string", "minLength": 1},
        "run_fingerprint": {"type": "string", "minLength": 12},
        "status": {"enum": ["succeeded", "failed"]},
        "classification": {"type": ["string", "null"]},
        "jobs": {"type": "integer", "minimum": 1},
        "artifact_prefix": {"type": "string"},
        "output_logical_hashes": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "runtime_replay_logical_hash",
            "counterfactual_replay_logical_hash",
            "metrics_canonical_logical_hash",
            "metrics_raw_sha256",
            "model_evaluation_hash"
          ],
          "properties": {
            "runtime_replay_logical_hash": {"$ref": "#/$defs/sha256Hex"},
            "counterfactual_replay_logical_hash": {"$ref": "#/$defs/sha256Hex"},
            "metrics_canonical_logical_hash": {"$ref": "#/$defs/sha256Hex"},
            "metrics_raw_sha256": {"$ref": "#/$defs/sha256Hex"},
            "model_evaluation_hash": {"type": "string", "minLength": 12}
          }
        },
        "errors": {"type": "array"},
        "runtime_activation": {"const": false},
        "a3_status": {"const": "open_macro_v03"},
        "a4_status": {"const": "harness_ready_provisional_A3"},
        "a5_status": {"const": "blocked"}
      }
    },
    "certified_input_pack_dry_run_result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "job_type",
        "job_id",
        "execution_id",
        "run_fingerprint",
        "status",
        "classification",
        "input_pack_id",
        "input_pack_sha256",
        "contract_bundle_sha256",
        "source_snapshot_sha256",
        "output_logical_hashes",
        "errors",
        "runtime_activation",
        "freeze_ready",
        "a3_status",
        "a4_status",
        "a5_status"
      ],
      "properties": {
        "schema_version": {"const": 1},
        "job_type": {"const": "certified_input_pack_dry_run"},
        "job_id": {"type": "string", "minLength": 1},
        "execution_id": {"type": "string", "minLength": 1},
        "run_fingerprint": {"$ref": "#/$defs/sha256Hex"},
        "status": {"const": "succeeded"},
        "classification": {"const": "input_pack_verified"},
        "input_pack_id": {"type": "string", "minLength": 1},
        "input_pack_sha256": {"$ref": "#/$defs/sha256Hex"},
        "contract_bundle_sha256": {"$ref": "#/$defs/sha256Hex"},
        "source_snapshot_sha256": {"$ref": "#/$defs/sha256Hex"},
        "output_logical_hashes": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "input_pack_sha256",
            "source_snapshot_sha256"
          ],
          "properties": {
            "input_pack_sha256": {"$ref": "#/$defs/sha256Hex"},
            "source_snapshot_sha256": {"$ref": "#/$defs/sha256Hex"}
          }
        },
        "errors": {
          "type": "array",
          "maxItems": 0
        },
        "runtime_activation": {"const": false},
        "freeze_ready": {"const": false},
        "a3_status": {"const": "open_macro_v03"},
        "a4_status": {"const": "input_pack_certified_for_calibration"},
        "a5_status": {"const": "blocked"}
      }
    },
    "open_macro_v03_metric_backtest_result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "job_type",
        "job_id",
        "execution_id",
        "run_fingerprint",
        "status",
        "classification",
        "input_pack_sha256",
        "contract_bundle_sha256",
        "output_logical_hashes",
        "execution_legs",
        "artifact_prefix",
        "errors",
        "runtime_activation",
        "a5_status",
        "official_result",
        "allocator_publish",
        "db_write",
        "production_endpoint_activation"
      ],
      "properties": {
        "schema_version": {"const": 1},
        "job_type": {"const": "open_macro_v03_metric_backtest"},
        "job_id": {"type": "string", "minLength": 1},
        "execution_id": {"type": "string", "minLength": 1},
        "run_fingerprint": {"$ref": "#/$defs/sha256Hex"},
        "status": {"enum": ["succeeded", "failed"]},
        "classification": {"const": "metric_evidence_only"},
        "input_pack_sha256": {"$ref": "#/$defs/sha256Hex"},
        "contract_bundle_sha256": {"$ref": "#/$defs/sha256Hex"},
        "output_logical_hashes": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "annualized_volatility",
            "max_drawdown",
            "out_of_sample_stability",
            "stress_window_behavior",
            "turnover",
            "metrics_canonical_logical_hash"
          ],
          "properties": {
            "annualized_volatility": {"$ref": "#/$defs/sha256Hex"},
            "max_drawdown": {"$ref": "#/$defs/sha256Hex"},
            "out_of_sample_stability": {"$ref": "#/$defs/sha256Hex"},
            "stress_window_behavior": {"$ref": "#/$defs/sha256Hex"},
            "turnover": {"$ref": "#/$defs/sha256Hex"},
            "metrics_canonical_logical_hash": {"$ref": "#/$defs/sha256Hex"}
          }
        },
        "execution_legs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["leg", "logical_hash"],
            "properties": {
              "leg": {"enum": ["local_python_pure", "qc_research_object_store"]},
              "logical_hash": {"$ref": "#/$defs/sha256Hex"}
            }
          }
        },
        "artifact_prefix": {"type": "string"},
        "errors": {"type": "array"},
        "runtime_activation": {"const": false},
        "a5_status": {"const": "blocked"},
        "official_result": {"const": false},
        "allocator_publish": {"const": false},
        "db_write": {"const": "none"},
        "production_endpoint_activation": {"const": "none"}
      }
    }
  }
}
